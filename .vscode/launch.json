{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Packet Analyzer",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/packet_analyzer.exe",
            "args": ["${workspaceFolder}/output.pcap"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/Users/mohit/Music/mingw32/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}